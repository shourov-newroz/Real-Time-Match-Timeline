{
  "name": "real-time-match-timeline",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "shared",
    "backend"
  ],
  "scripts": {
    "dev": "vite",
    "dev:backend": "npm run dev --workspace=@rtmt/backend",
    "dev:all": "concurrently -n client,server -c blue,green \"npm run dev\" \"npm run dev:backend\"",
    "build": "tsc -b && vite build",
    "build:backend": "npm run build --workspace=@rtmt/backend",
    "start": "npm run start --workspace=@rtmt/backend",
    "start:backend": "npm run start --workspace=@rtmt/backend",
    "preview": "vite preview",
    "test:run": "tsc -b --pretty false"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "motion": "^12.40.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-window": "^2.2.7",
    "socket.io-client": "^4.8.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.3"
  }
}
